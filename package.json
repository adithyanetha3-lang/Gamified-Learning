{
  "name": "skill-park-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "echo 'Add ESLint configuration for production'",
    "start:all": "npm run dev & cd server && npm run dev",
    "docker:build": "docker build -t skill-park:latest .",
    "docker:run": "docker run -d -p 3000:3000 --env-file .env skill-park:latest",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "firebase": "^11.6.1",
    "framer-motion": "^12.9.2",
    "i18next": "^26.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "terser": "^5.37.0",
    "vite": "^6.3.2"
  }
}
